# PostgreSQL Database Configuration
# These values match the docker-compose.yml defaults for local deployment
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_db
DB_USER=attendance_user
DB_PASSWORD=attendance_pass
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME?connection pooling=true?limit=20   ?sslmode=disable}
