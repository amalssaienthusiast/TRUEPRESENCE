# TruePresence — environment variables
# Copy this file to .env and adjust as needed.
# SQLite requires NO database server — it is all managed automatically.

# ── SQLite database file path (created automatically) ────────────────────
# Default: data/attendance.db (relative to project root)
DB_PATH=data/attendance.db

# ── Anti-Spoofing API (optional — only if antispoof module is running) ───
ANTISPOOF_API_URL=http://localhost:8001

# ── Roboflow API (optional — only for downloading detection datasets) ────
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# ── Anti-Spoofing model checkpoint paths ────────────────────────────────
ANTISPOOF_CKPT=antispoof/checkpoints/best_antispoof.onnx
SCREEN_CKPT=antispoof/checkpoints/best_screen_detector.pt
DLIB_LANDMARKS=data/data_dlib/shape_predictor_68_face_landmarks.dat
