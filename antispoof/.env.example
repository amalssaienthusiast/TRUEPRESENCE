# ── Database (shared with main attendance system) ──────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_db
DB_USER=attendance_user
DB_PASSWORD=attendance_pass

# ── Roboflow API ────────────────────────────────────────────────────────────
# Get your key at https://app.roboflow.com → Account Settings → Roboflow API
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# ── FastAPI / API layer ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
SESSION_TTL_SECONDS=30

# ── Model checkpoint paths ──────────────────────────────────────────────────
ANTISPOOF_CKPT=checkpoints/best_antispoof.onnx
SCREEN_CKPT=checkpoints/best_screen_detector.pt
DLIB_LANDMARKS=../data/data_dlib/shape_predictor_68_face_landmarks.dat

# ── Training ────────────────────────────────────────────────────────────────
DATA_ROOT=./data
LOG_DIR=./runs
